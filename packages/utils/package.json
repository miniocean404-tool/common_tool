{
  "name": "@mini/utils",
  "version": "1.0.0",
  "description": "mini 自用工具库",
  "type": "module",
  "main": "./dist/index",
  "module": "./dist/index",
  "browser": {
    "./web": "./dist/web",
    "./array": "./dist/array",
    "./format": "./dist/format",
    "./pref": "./dist/pref",
    "./normalize": "./dist/normalize"
  },
  "exports": {
    ".": {
      "default": "./dist/index",
      "import": "./dist/index",
      "types": "./dist/index.d.ts"
    },
    "./web": {
      "default": "./dist/web",
      "import": "./dist/web",
      "types": "./dist/web.d.ts"
    },
    "./array": {
      "default": "./dist/array",
      "types": "./dist/array.d.ts"
    },
    "./format": {
      "default": "./dist/format",
      "types": "./dist/format.d.ts"
    },
    "./pref": {
      "default": "./dist/pref",
      "types": "./dist/pref.d.ts"
    },
    "./normalize": {
      "default": "./dist/normalize",
      "types": "./dist/normalize.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/*",
    "package.json"
  ],
  "scripts": {
    "watch:tsc": "tsc --watch --project ./tsconfig.json",
    "build": "tsc --project ./tsconfig.json "
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "prettier": "3.3.3"
  }
}
