{
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./src",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "sourceMap": false,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    // 是否跳过类型检查
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    // 是否输出文件
    "noEmit": false,
    // 是否只输出 .d.ts 文件, 不输出 .js 文件
    "emitDeclarationOnly": false,
    // 控制是否允许在导入模块时使用 .ts 文件扩展名
    "allowImportingTsExtensions": false,
    // 是否输出类型声明文件
    "declaration": true
  },
  "include": ["./src/**/*.ts"]
}
